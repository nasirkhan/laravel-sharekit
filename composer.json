{
  "name": "nasirkhan/laravel-sharekit",
  "description": "Reusable social sharing Blade components for Laravel with themeable styles, metadata auto-detection, and page-scoped assets.",
  "keywords": [
    "laravel",
    "sharing",
    "social-share",
    "social-sharing",
    "blade-components",
    "share-buttons",
    "share-links",
    "sharekit",
    "web-share-api",
    "frontend"
  ],
  "license": "GPL-3.0-or-later",
  "type": "library",
  "authors": [
    {
      "name": "Nasir Khan Saikat",
      "email": "nasir8891@gmail.com",
      "homepage": "https://github.com/nasirkhan",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/nasirkhan/laravel-sharekit",
  "require": {
    "php": "^8.3",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/view": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^11.0|^12.0"
  },
  "autoload": {
    "psr-4": {
      "Nasirkhan\\LaravelSharekit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nasirkhan\\LaravelSharekit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Nasirkhan\\LaravelSharekit\\SharekitServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true
  }
}
